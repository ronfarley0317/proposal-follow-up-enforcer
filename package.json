{
  "name": "proposal-follow-up-enforcer-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Milestone 1 service skeleton for the Proposal Follow-Up Enforcer runtime.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "test:contracts": "tsx src/scripts/test-contracts.ts",
    "test:events": "tsx src/scripts/test-event-schema.ts",
    "test:scenarios": "tsx src/scripts/test-scenarios.ts",
    "test:state": "tsx src/scripts/test-state-transitions.ts",
    "test:failures": "tsx src/scripts/test-failure-modes.ts",
    "test:v1": "tsx src/scripts/test-contracts.ts && tsx src/scripts/test-event-schema.ts && tsx src/scripts/test-scenarios.ts && tsx src/scripts/test-state-transitions.ts && tsx src/scripts/test-failure-modes.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "pg": "^8.16.3",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
